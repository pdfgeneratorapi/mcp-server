# Server configuration
PORT=3000
LOG_LEVEL=info

# API Base URL
API_BASE_URL=https://us1.pdfgeneratorapi.com/api/v4

# Bearer token (stdio mode only)
# In HTTP mode, pass the token via "Authorization: Bearer <token>" header per-request
# BEARER_TOKEN_JWT=your-jwt-token-here

# Session idle timeout in minutes (HTTP mode only)
# SESSION_TTL_MINUTES=30

# CORS allowed origins — comma-separated (HTTP mode only)
# Default is "*" (all origins). Restrict in production:
# CORS_ORIGIN=https://your-app.example.com
