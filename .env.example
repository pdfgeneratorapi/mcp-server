# Server configuration
PORT=3000
LOG_LEVEL=info

# API Base URL
API_BASE_URL=https://us1.pdfgeneratorapi.com/api/v4

# Bearer token (optional for stdio mode)
# BEARER_TOKEN_JWT=your-jwt-token-here

# Note: Bearer tokens are handled differently per transport mode:
# - HTTP mode: Pass token in "Authorization: Bearer <your-token>" header per-request
# - Stdio mode: Pass token via BEARER_TOKEN_JWT environment variable in MCP client config